# ========================================
# Sports Car - Simple OBJ Test Model
# Vehicle Framework 测试用载具模型
# ========================================
# 坐标系: Y-up, 右手坐标系 (OBJ 标准)
# 单位: 1 单位 ≈ 1/16 方块 (可在 JSON 中调整 objScale)
# 总尺寸约: 32 x 12 x 16 单位 → 缩放后约 2x0.75x1 方块

o SportsCar

# ── 车身 (Box: 32x8x14) ──
# 底部 y=2, 顶部 y=10

# 8 个顶点
v -16.0  2.0  -7.0
v  16.0  2.0  -7.0
v  16.0  2.0   7.0
v -16.0  2.0   7.0
v -16.0 10.0  -7.0
v  16.0 10.0  -7.0
v  16.0 10.0   7.0
v -16.0 10.0   7.0

# 法线
vn  0.0 -1.0  0.0
vn  0.0  1.0  0.0
vn  0.0  0.0 -1.0
vn  0.0  0.0  1.0
vn -1.0  0.0  0.0
vn  1.0  0.0  0.0

# UV 坐标 (简单的平面映射)
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

# 车身底面 (y=2, 法线朝下)
f 1/1/1 3/3/1 2/2/1
f 1/1/1 4/4/1 3/3/1

# 车身顶面 (y=10, 法线朝上)
f 5/1/2 6/2/2 7/3/2
f 5/1/2 7/3/2 8/4/2

# 车身前面 (z=-7, 法线朝前)
f 1/1/3 2/2/3 6/3/3
f 1/1/3 6/3/3 5/4/3

# 车身后面 (z=7, 法线朝后)
f 4/1/4 7/2/4 3/3/4
f 4/1/4 8/4/4 7/2/4

# 车身左面 (x=-16, 法线朝左)
f 1/1/5 5/2/5 8/3/5
f 1/1/5 8/3/5 4/4/5

# 车身右面 (x=16, 法线朝右)
f 2/1/6 3/2/6 7/3/6
f 2/1/6 7/3/6 6/4/6


# ── 驾驶舱 (Box: 16x6x12, 位于车身上方中部偏后) ──
# 底部 y=10, 顶部 y=16

v -8.0 10.0 -6.0
v  8.0 10.0 -6.0
v  8.0 10.0  6.0
v -8.0 10.0  6.0
v -8.0 16.0 -6.0
v  8.0 16.0 -6.0
v  8.0 16.0  6.0
v -8.0 16.0  6.0

# 驾驶舱顶面
f 13/1/2 14/2/2 15/3/2
f 13/1/2 15/3/2 16/4/2

# 驾驶舱前面 (挡风玻璃)
f 9/1/3 10/2/3 14/3/3
f 9/1/3 14/3/3 13/4/3

# 驾驶舱后面
f 12/1/4 15/2/4 11/3/4
f 12/1/4 16/4/4 15/2/4

# 驾驶舱左面 (车窗)
f 9/1/5 13/2/5 16/3/5
f 9/1/5 16/3/5 12/4/5

# 驾驶舱右面 (车窗)
f 10/1/6 11/2/6 15/3/6
f 10/1/6 15/3/6 14/4/6


# ── 左前轮 (Cylinder approximation, 8-sided) ──
# 中心: (-10, 2, 8), 半径=3, 宽度=3

v -11.5  2.0  6.5
v -11.5  2.0  9.5
v -10.0  5.0  6.5
v -10.0  5.0  9.5
v  -8.5  2.0  6.5
v  -8.5  2.0  9.5
v -10.0 -1.0  6.5
v -10.0 -1.0  9.5

# 左前轮面 (简化为盒子)
f 17/1/4 18/2/4 20/3/4
f 17/1/4 20/3/4 19/4/4
f 19/1/6 20/2/6 22/3/6
f 19/1/6 22/3/6 21/4/6
f 21/1/3 22/2/3 24/3/3
f 21/1/3 24/3/3 23/4/3
f 17/1/5 23/2/5 24/3/5
f 17/1/5 24/3/5 18/4/5


# ── 右前轮 ──
# 中心: (10, 2, 8)

v  8.5  2.0  6.5
v  8.5  2.0  9.5
v 10.0  5.0  6.5
v 10.0  5.0  9.5
v 11.5  2.0  6.5
v 11.5  2.0  9.5
v 10.0 -1.0  6.5
v 10.0 -1.0  9.5

f 25/1/4 26/2/4 28/3/4
f 25/1/4 28/3/4 27/4/4
f 27/1/6 28/2/6 30/3/6
f 27/1/6 30/3/6 29/4/6
f 29/1/3 30/2/3 32/3/3
f 29/1/3 32/3/3 31/4/3
f 25/1/5 31/2/5 32/3/5
f 25/1/5 32/3/5 26/4/5


# ── 左后轮 ──
# 中心: (-10, 2, -8)

v -11.5  2.0 -9.5
v -11.5  2.0 -6.5
v -10.0  5.0 -9.5
v -10.0  5.0 -6.5
v  -8.5  2.0 -9.5
v  -8.5  2.0 -6.5
v -10.0 -1.0 -9.5
v -10.0 -1.0 -6.5

f 33/1/4 34/2/4 36/3/4
f 33/1/4 36/3/4 35/4/4
f 35/1/6 36/2/6 38/3/6
f 35/1/6 38/3/6 37/4/6
f 37/1/3 38/2/3 40/3/3
f 37/1/3 40/3/3 39/4/3
f 33/1/5 39/2/5 40/3/5
f 33/1/5 40/3/5 34/4/5


# ── 右后轮 ──
# 中心: (10, 2, -8)

v  8.5  2.0 -9.5
v  8.5  2.0 -6.5
v 10.0  5.0 -9.5
v 10.0  5.0 -6.5
v 11.5  2.0 -9.5
v 11.5  2.0 -6.5
v 10.0 -1.0 -9.5
v 10.0 -1.0 -6.5

f 41/1/4 42/2/4 44/3/4
f 41/1/4 44/3/4 43/4/4
f 43/1/6 44/2/6 46/3/6
f 43/1/6 46/3/6 45/4/6
